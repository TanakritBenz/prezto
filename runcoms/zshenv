#
# Defines environment variables.
# This file is sourced on every zsh invocation (interactive and non-interactive)
#

# Ensure that a non-login, non-interactive shell has a defined environment.
if [[ ( "$SHLVL" -eq 1 && ! -o LOGIN ) && -s "${ZDOTDIR:-$HOME}/.zprofile" ]]; then
  source "${ZDOTDIR:-$HOME}/.zprofile"
fi

## Shell history settings
HISTFILE=~/.histfile
HISTSIZE=1000000
SAVEHIST=1000000

## GitHub username
export GITHUB_USERNAME="TanakritBenz"

## Base PATH
export PATH="$HOME/bin:/opt/homebrew/bin:/bin:/sbin:/usr/local/bin:/usr/bin:/usr/sbin:/usr/libexec:$PATH"

## Go
GOLANG_PREFIX=$(brew --prefix golang)
export GOPATH=$HOME/go
export GOROOT="$GOLANG_PREFIX/libexec"
export PATH="$PATH:$GOPATH/bin:$GOROOT/bin"

## Flutter & Android
export ANDROID_SDK_ROOT="$HOME/Library/Android/sdk"
export PATH="$PATH:$ANDROID_SDK_ROOT/platform-tools"
export PATH="$PATH:$HOME/Dev/flutter/bin"

## Java
export JAVA_HOME="/Applications/Android Studio.app/Contents/jbr/Contents/Home"
export PATH="$JAVA_HOME/bin:$PATH"

## NVM
export NVM_DIR="$HOME/.nvm"
export NODE_PATH=$(which node)

## Bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

## Windsurf
export PATH="/Users/benz/.codeium/windsurf/bin:$PATH"

## LM Studio CLI
export PATH="$PATH:/Users/benz/.lmstudio/bin"

## Google Cloud SDK
if [[ -f "$HOME/Downloads/google-cloud-sdk/path.zsh.inc" ]]; then
  source "$HOME/Downloads/google-cloud-sdk/path.zsh.inc"
fi

## uv/uvx Python package manager
. "$HOME/.local/bin/env"

## Claude Code
export CLAUDE_CODE_EFFORT_LEVEL=max

## Source private secrets (API keys, tokens, etc.)
[[ -f "$HOME/.zshenv.local" ]] && source "$HOME/.zshenv.local"
